{
  "compilerOptions": {
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "rootDirs": [".", "./.react-router/types"],
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "types": ["vite/client"],
    "verbatimModuleSyntax": true
  },
  "include": ["app", ".react-router/types/**/*", "app/root.tsx", "app/routes.ts"]
}
